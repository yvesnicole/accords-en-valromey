---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/ui/Card.astro';
---

<BaseLayout title="Contact — Accords en Valromey" description="Contact the Accords en Valromey festival" lang="en">
  <section class="relative h-64 md:h-80 overflow-hidden">
    <div class="absolute inset-0 bg-[#1A1A1A]/40 z-10"></div>
    <img
      src="/images/scenery/paysage.jpg"
      alt="Valromey"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="relative z-20 flex items-center justify-center h-full">
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-contrast">Contact</h1>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-6 py-section">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <Card>
        <h3 class="font-serif text-xl font-semibold text-[#1A1A1A] mb-4">Address</h3>
        <address class="font-sans text-gray-700 not-italic leading-relaxed">
          Festival Accords en Valromey<br />
          Mairie de Champagne-en-Valromey<br />
          01260 Champagne-en-Valromey<br />
          France
        </address>
      </Card>
      <Card>
        <h3 class="font-serif text-xl font-semibold text-[#1A1A1A] mb-4">Email</h3>
        <p class="font-sans text-gray-700">
          <a href="mailto:contact@accordsenvalromey.fr" class="text-[#1A1A1A] underline hover:text-sage transition-colors">
            contact@accordsenvalromey.fr
          </a>
        </p>
      </Card>
    </div>
  </section>

  <section class="bg-contrast py-section">
    <div class="max-w-4xl mx-auto px-6">
      <div class="rounded-card overflow-hidden">
        <img
          src="/images/scenery/eglise.jpg"
          alt="Saint-Symphorien Church"
          class="w-full h-64 md:h-96 object-cover"
        />
        <div class="p-4 bg-ivory text-center">
          <p class="font-sans text-sm text-gray-500">
            Saint-Symphorien Church — Champagne-en-Valromey, Ain
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
