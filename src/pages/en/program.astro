---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../../components/ui/SectionTitle.astro';
import ConcertCarousel from '../../components/concerts/ConcertCarousel.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getConcerts } from '../../lib/data';
import { mapConcertToProps } from '../../lib/utils';

const locale = getLangFromUrl(Astro.url) as 'fr' | 'en';
const rawConcerts = await getConcerts(locale);
const concerts = rawConcerts.map(c => mapConcertToProps(c, locale));
---

<BaseLayout title="Program — Accords en Valromey" description="Discover the Accords en Valromey festival program" lang="en">
  <section class="relative h-64 md:h-80 overflow-hidden">
    <div class="absolute inset-0 bg-[#1A1A1A]/40 z-10"></div>
    <img
      src="/images/scenery/paysage.jpg"
      alt="Valromey landscape"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="relative z-20 flex items-center justify-center h-full">
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-contrast">Program</h1>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 py-section">
    <SectionTitle
      title="The Concerts"
      subtitle="Three exceptional concerts in Champagne Church, all at 7:00 PM from August 20 to 22, 2026."
    />
    <p class="max-w-3xl mx-auto font-sans text-lg text-gray-700 leading-relaxed text-center mb-12">
      Discover a program that combines great classics, lesser-known works, and a major research project devoted to overlooked composer Alice Lesur, whom we are honoring this year. Click on a poster to learn more.
    </p>
    {concerts.length > 0 ? (
      <ConcertCarousel concerts={concerts} />
    ) : (
      <p class="text-center text-gray-500 py-section">
        No concerts announced yet.
      </p>
    )}
  </section>
</BaseLayout>