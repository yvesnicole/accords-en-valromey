---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../../components/ui/SectionTitle.astro';
import ConcertCarousel from '../../components/concerts/ConcertCarousel.astro';

const concerts = [
  {
    title: 'Opening Concert',
    date: 'August 20, 2026 — 7:00 PM',
    description: 'A journey through 20th century chamber music, with works by Shostakovich, Lili Boulanger, Ravel, and Rebecca Clarke. This opening concert sets the tone for the festival: musical excellence and rediscovery of forgotten women composers.',
    poster: '/images/concerts/ouverture.jpg',
    mapsLink: 'https://www.google.com/maps/place/Paroisse+de+Champagne+En+Valromey+./@45.9045508,5.6759187,993m/data=!3m2!1e3!4b1!4m6!3m5!1s0x478b68b29359f9d1:0xa52260d492b15338!8m2!3d45.9045508!4d5.6784936!16s%2Fg%2F1tjcnbkd?entry=ttu&g_ep=EgoyMDI2MDUyNi4wIKXMDSoASAFQAw%3D%3D',
    ticketLink: 'https://www.helloasso.com/associations/accords-en-valromey',
    mapsLabel: 'View on Google Maps',
    ticketLabel: 'Book tickets',
  },
  {
    title: 'Tribute to Alice Lesur',
    date: 'August 21, 2026 — 7:00 PM',
    description: 'A tribute to French composer Alice Lesur, an overlooked figure of 20th century music. Her grandson, Christian Lesur, will be present to share his grandmother\'s story and work with the audience. A unique moment of transmission and emotion.',
    poster: '/images/concerts/lesur.jpg',
    mapsLink: 'https://www.google.com/maps/place/Paroisse+de+Champagne+En+Valromey+./@45.9045508,5.6759187,993m/data=!3m2!1e3!4b1!4m6!3m5!1s0x478b68b29359f9d1:0xa52260d492b15338!8m2!3d45.9045508!4d5.6784936!16s%2Fg%2F1tjcnbkd?entry=ttu&g_ep=EgoyMDI2MDUyNi4wIKXMDSoASAFQAw%3D%3D',
    ticketLink: 'https://www.helloasso.com/associations/accords-en-valromey',
    mapsLabel: 'View on Google Maps',
    ticketLabel: 'Book tickets',
  },
  {
    title: 'Closing Concert',
    date: 'August 22, 2026 — 7:00 PM',
    description: 'The festival concludes in grand style with major romantic works by Schumann, Mendelssohn, and Brahms\' piano quintet. A magnificent finale bringing together all the festival musicians for an exceptional moment.',
    poster: '/images/concerts/cloture.jpg',
    mapsLink: 'https://www.google.com/maps/place/Paroisse+de+Champagne+En+Valromey+./@45.9045508,5.6759187,993m/data=!3m2!1e3!4b1!4m6!3m5!1s0x478b68b29359f9d1:0xa52260d492b15338!8m2!3d45.9045508!4d5.6784936!16s%2Fg%2F1tjcnbkd?entry=ttu&g_ep=EgoyMDI2MDUyNi4wIKXMDSoASAFQAw%3D%3D',
    ticketLink: 'https://www.helloasso.com/associations/accords-en-valromey',
    mapsLabel: 'View on Google Maps',
    ticketLabel: 'Book tickets',
  },
];
---

<BaseLayout title="Program — Accords en Valromey" description="Discover the Accords en Valromey festival program" lang="en">
  <section class="relative h-64 md:h-80 overflow-hidden">
    <div class="absolute inset-0 bg-[#1A1A1A]/40 z-10"></div>
    <img
      src="/images/scenery/paysage.jpg"
      alt="Valromey landscape"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="relative z-20 flex items-center justify-center h-full">
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-contrast">Program</h1>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 py-section">
    <SectionTitle
      title="The Concerts"
      subtitle="Three exceptional concerts in Saint-Pierre Church, all at 7:00 PM from August 20 to 22, 2026."
    />
    <p class="max-w-3xl mx-auto font-sans text-lg text-gray-700 leading-relaxed text-center mb-12">
      Discover a program that combines great classics, lesser-known works, and a major research project devoted to overlooked composer Alice Lesur, whom we are honoring this year. Click on a poster to learn more.
    </p>
    <ConcertCarousel concerts={concerts} />
  </section>
</BaseLayout>
