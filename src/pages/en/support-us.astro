---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../../components/ui/SectionTitle.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';
import { getSupportInfo } from '../../lib/data';

const locale = 'en' as const;
const support = await getSupportInfo(locale);
---

<BaseLayout title="Support Us — Accords en Valromey" description="Support the Accords en Valromey festival" lang="en">
  <section class="relative h-64 md:h-80 overflow-hidden">
    <div class="absolute inset-0 bg-[#1A1A1A]/40 z-10"></div>
    <img
      src="/images/scenery/paysage.jpg"
      alt="Valromey"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="relative z-20 flex items-center justify-center h-full">
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-contrast">Support Us</h1>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 py-section">
    <SectionTitle
      title="Support the Festival"
      subtitle={support?.subtitle || "Your contribution helps keep classical music alive in the Valromey and supports young talent."}
    />
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-12">
      <Card>
        <h3 class="font-serif text-2xl font-semibold text-[#1A1A1A] mb-4">{support?.membershipTitle || 'Join the Association'}</h3>
        <p class="font-sans text-gray-700 leading-relaxed mb-6">
          {support?.membershipText || "Become a member of the association and participate in the life of the festival. Priority access to concerts, meetings with artists, and much more."}
        </p>
        <Button href={support?.membershipUrl || 'https://www.helloasso.com/associations/accords-en-valromey'} external variant="primary">
          Join
        </Button>
      </Card>
      <Card>
        <h3 class="font-serif text-2xl font-semibold text-[#1A1A1A] mb-4">{support?.donationTitle || 'Donate'}</h3>
        <p class="font-sans text-gray-700 leading-relaxed mb-6">
          {support?.donationText || "Make a donation to support the program, host artists, and grow the festival. Every contribution counts."}
        </p>
        <Button href={support?.donationUrl || 'https://www.helloasso.com/associations/accords-en-valromey'} external variant="primary">
          Donate
        </Button>
      </Card>
    </div>
  </section>
</BaseLayout>