---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../../components/ui/SectionTitle.astro';
import Card from '../../components/ui/Card.astro';

const t = (key: string) => key;
---

<BaseLayout title="The Festival — Accords en Valromey" description="History and identity of the Accords en Valromey festival" lang="en">
  <section class="relative h-64 md:h-80 overflow-hidden">
    <div class="absolute inset-0 bg-[#1A1A1A]/40 z-10"></div>
    <img
      src="/images/scenery/paysage.jpg"
      alt="Valromey landscape"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="relative z-20 flex items-center justify-center h-full">
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-contrast">The Festival</h1>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 py-section">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 lg:gap-20 items-start">
      <div class="space-y-6 font-sans text-lg text-gray-700 leading-relaxed">
        <p>
          Accords en Valromey was born from cellist Célia Garetti-Nicole's dream of bringing classical
          music back to her home region of Champagne-en-Valromey. After studying at the conservatories
          of Paris, Brussels, and Mannheim, she founded the festival in 2022 with Véronique and Hervé
          to create concerts that are artistically ambitious, welcoming, and deeply rooted in the Valromey.
        </p>
        <p>
          The association grew thanks to volunteers, musicians, and local residents committed to the
          cultural life of the valley. Alain, the stage manager, and Michel, the association's secretary,
          help shape a collective project that gathers outstanding young artists in Champagne church,
          then around post-concert cocktails where audiences and musicians can meet.
        </p>
        <p>
          A central mission of the festival is to rediscover overlooked women composers such as Lili
          Boulanger, Rebecca Clarke, and Alice Lesur. This spirit of transmission, curiosity, and
          closeness makes Accords en Valromey an intimate, community-driven festival true to the
          character of the Valromey.
        </p>
      </div>
      <div class="rounded-card overflow-hidden bg-contrast">
        <img
          src="/images/scenery/eglise.jpg"
           alt="Champagne Church"
          class="w-full h-auto object-contain"
        />
        <p class="p-4 text-center font-sans text-sm text-gray-500">
           Champagne Church — Champagne-en-Valromey, Ain
        </p>
      </div>
    </div>
  </section>

</BaseLayout>
