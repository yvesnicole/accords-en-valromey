---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../../components/ui/SectionTitle.astro';
import MusicianGrid from '../../components/musicians/MusicianGrid.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getMusicians } from '../../lib/data';
import { mapMusicianToProps, renderMarkdown } from '../../lib/utils';

const locale = getLangFromUrl(Astro.url) as 'fr' | 'en';
const rawMusicians = await getMusicians(locale);
const musicians = await Promise.all(
  rawMusicians.map(async (m) => {
    const props = mapMusicianToProps(m);
    return {
      ...props,
      biography: props.biography ? await renderMarkdown(props.biography) : '',
    };
  })
);
---

<BaseLayout title="Musicians — Accords en Valromey" description="Discover the musicians of the Accords en Valromey festival" lang="en">
  <section class="relative h-64 md:h-80 overflow-hidden">
    <div class="absolute inset-0 bg-[#1A1A1A]/40 z-10"></div>
    <img
      src="/images/scenery/paysage.jpg"
      alt="Valromey landscape"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="relative z-20 flex items-center justify-center h-full">
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-contrast">Musicians</h1>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 py-section">
    <SectionTitle
      title="Our Musicians"
      subtitle="Exceptional young talents gathered for the festival."
    />
    {musicians.length > 0 ? (
      <MusicianGrid musicians={musicians} locale="en" />
    ) : (
      <p class="text-center text-gray-500 py-section">
        No musicians to display at this time.
      </p>
    )}
  </section>
</BaseLayout>