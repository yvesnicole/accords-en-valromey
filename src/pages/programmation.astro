---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTitle from '../components/ui/SectionTitle.astro';
import ConcertList from '../components/concerts/ConcertList.astro';

const concerts = [
  {
    title: "Concert d'Ouverture",
    date: '20 août 2026 — 19h00',
    summary: 'Un voyage à travers la musique de chambre du XXe siècle, avec Chostakovitch, Lili Boulanger, Ravel et Rebecca Clarke.',
    image: '/images/scenery/eglise.jpg',
    helloAssoLink: 'https://www.helloasso.com/associations/accords-en-valromey',
  },
  {
    title: 'Hommage à Alice Lesur',
    date: '21 août 2026 — 19h00',
    summary: 'Un hommage à Alice Lesur avec la présence de son petit-fils Christian Lesur et des œuvres d\'Alice Lesur et d\'Olivier Messiaen.',
    image: '/images/scenery/eglise.jpg',
    helloAssoLink: 'https://www.helloasso.com/associations/accords-en-valromey',
  },
  {
    title: 'Concert de Clôture',
    date: '22 août 2026 — 19h00',
    summary: 'Le festival s\'achève avec Schumann, Mendelssohn et le quintette avec piano de Brahms dans un grand final romantique.',
    image: '/images/scenery/eglise.jpg',
    helloAssoLink: 'https://www.helloasso.com/associations/accords-en-valromey',
  },
];
---

<BaseLayout title="Programmation — Accords en Valromey" description="Découvrez la programmation du festival Accords en Valromey">
  <section class="relative h-64 md:h-80 overflow-hidden">
    <div class="absolute inset-0 bg-[#1A1A1A]/40 z-10"></div>
    <img
      src="/images/scenery/eglise.jpg"
      alt="Concert"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="relative z-20 flex items-center justify-center h-full">
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-contrast">Programmation</h1>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 py-section">
    <SectionTitle
      title="Les Concerts"
      subtitle="Trois concerts exceptionnels dans l'écrin de l'église Saint-Pierre, tous à 19h00 du 20 au 22 août 2026."
    />
    <p class="max-w-3xl mx-auto font-sans text-lg text-gray-700 leading-relaxed text-center mb-12">
      Découvrez ici notre programmation qui mêle grands classiques, œuvres moins connues et un projet de recherche consacré à la compositrice oubliée Alice Lesur, à qui nous rendons hommage cette année.
    </p>
    <ConcertList concerts={concerts} />
    <div class="grid grid-cols-1 gap-8 mt-12">
      <div class="bg-contrast rounded-card p-8">
        <h2 class="font-serif text-2xl font-semibold text-[#1A1A1A] mb-3">Concert d'Ouverture — 20 août 2026, 19h00</h2>
        <p class="font-sans text-gray-700 leading-relaxed mb-6">
          Un voyage à travers la musique de chambre du XXe siècle, avec des œuvres de Chostakovitch, Lili Boulanger, Ravel et Rebecca Clarke. Ce concert d'ouverture donne le ton du festival : excellence musicale et redécouverte de compositrices oubliées.
        </p>
        <object data="/posters/Concert%20Ouverture%20affiche%20.pdf" type="application/pdf" class="w-full h-64">
          <p><a href="/posters/Concert%20Ouverture%20affiche%20.pdf" class="underline">Voir l'affiche du concert d'ouverture</a></p>
        </object>
      </div>
      <div class="bg-contrast rounded-card p-8">
        <h2 class="font-serif text-2xl font-semibold text-[#1A1A1A] mb-3">Hommage à Alice Lesur — 21 août 2026, 19h00</h2>
        <p class="font-sans text-gray-700 leading-relaxed mb-6">
          Un hommage à la compositrice française Alice Lesur, figure méconnue de la musique du XXe siècle. Son petit-fils, Christian Lesur, sera présent pour partager avec le public l'histoire et l'œuvre de sa grand-mère. Un moment unique de transmission et d'émotion.
        </p>
        <object data="/posters/Concert%20Lesur%20affiche%20.pdf" type="application/pdf" class="w-full h-64">
          <p><a href="/posters/Concert%20Lesur%20affiche%20.pdf" class="underline">Voir l'affiche du concert Alice Lesur</a></p>
        </object>
      </div>
      <div class="bg-contrast rounded-card p-8">
        <h2 class="font-serif text-2xl font-semibold text-[#1A1A1A] mb-3">Concert de Clôture — 22 août 2026, 19h00</h2>
        <p class="font-sans text-gray-700 leading-relaxed mb-6">
          Le festival s'achève en apothéose avec les grandes œuvres romantiques de Schumann, Mendelssohn et le quintette pour piano de Brahms. Un final grandiose réunissant l'ensemble des musiciens du festival pour un moment d'exception.
        </p>
        <object data="/posters/Copie%20de%20Concert%20Clôture%20affiche%20.pdf" type="application/pdf" class="w-full h-64">
          <p><a href="/posters/Copie%20de%20Concert%20Clôture%20affiche%20.pdf" class="underline">Voir l'affiche du concert de clôture</a></p>
        </object>
      </div>
    </div>
  </section>
</BaseLayout>
