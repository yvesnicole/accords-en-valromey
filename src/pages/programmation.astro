---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTitle from '../components/ui/SectionTitle.astro';
import ConcertCarousel from '../components/concerts/ConcertCarousel.astro';

const concerts = [
  {
    title: "Concert d'Ouverture",
    date: '20 août 2026 — 19h00',
    description: "Un voyage à travers la musique de chambre du XXe siècle, avec des œuvres de Chostakovitch, Lili Boulanger, Ravel et Rebecca Clarke. Ce concert d'ouverture donne le ton du festival : excellence musicale et redécouverte de compositrices oubliées.",
    poster: '/images/concerts/ouverture.jpg',
    mapsLink: 'https://www.google.com/maps/place/Paroisse+de+Champagne+En+Valromey+./@45.9045508,5.6759187,993m/data=!3m2!1e3!4b1!4m6!3m5!1s0x478b68b29359f9d1:0xa52260d492b15338!8m2!3d45.9045508!4d5.6784936!16s%2Fg%2F1tjcnbkd?entry=ttu&g_ep=EgoyMDI2MDUyNi4wIKXMDSoASAFQAw%3D%3D',
    ticketLink: '/billetterie/',
    mapsLabel: 'Voir sur Google Maps',
    ticketLabel: 'Réserver',
  },
  {
    title: 'Hommage à Alice Lesur',
    date: '21 août 2026 — 19h00',
    description: "Un hommage à la compositrice française Alice Lesur, figure méconnue de la musique du XXe siècle. Son petit-fils, Christian Lesur, sera présent pour partager avec le public l'histoire et l'œuvre de sa grand-mère. Un moment unique de transmission et d'émotion.",
    poster: '/images/concerts/lesur.jpg',
    mapsLink: 'https://www.google.com/maps/place/Paroisse+de+Champagne+En+Valromey+./@45.9045508,5.6759187,993m/data=!3m2!1e3!4b1!4m6!3m5!1s0x478b68b29359f9d1:0xa52260d492b15338!8m2!3d45.9045508!4d5.6784936!16s%2Fg%2F1tjcnbkd?entry=ttu&g_ep=EgoyMDI2MDUyNi4wIKXMDSoASAFQAw%3D%3D',
    ticketLink: '/billetterie/',
    mapsLabel: 'Voir sur Google Maps',
    ticketLabel: 'Réserver',
  },
  {
    title: 'Concert de Clôture',
    date: '22 août 2026 — 19h00',
    description: "Le festival s'achève en apothéose avec les grandes œuvres romantiques de Schumann, Mendelssohn et le quintette pour piano de Brahms. Un final grandiose réunissant l'ensemble des musiciens du festival pour un moment d'exception.",
    poster: '/images/concerts/cloture.jpg',
    mapsLink: 'https://www.google.com/maps/place/Paroisse+de+Champagne+En+Valromey+./@45.9045508,5.6759187,993m/data=!3m2!1e3!4b1!4m6!3m5!1s0x478b68b29359f9d1:0xa52260d492b15338!8m2!3d45.9045508!4d5.6784936!16s%2Fg%2F1tjcnbkd?entry=ttu&g_ep=EgoyMDI2MDUyNi4wIKXMDSoASAFQAw%3D%3D',
    ticketLink: '/billetterie/',
    mapsLabel: 'Voir sur Google Maps',
    ticketLabel: 'Réserver',
  },
];
---

<BaseLayout title="Programmation — Accords en Valromey" description="Découvrez la programmation du festival Accords en Valromey">
  <section class="relative h-64 md:h-80 overflow-hidden">
    <div class="absolute inset-0 bg-[#1A1A1A]/40 z-10"></div>
    <img
      src="/images/scenery/paysage.jpg"
      alt="Valromey landscape"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="relative z-20 flex items-center justify-center h-full">
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-contrast">Programmation</h1>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 py-section">
    <SectionTitle
      title="Les Concerts"
      subtitle="Trois concerts exceptionnels dans l'écrin de l'église Saint-Pierre, tous à 19h00 du 20 au 22 août 2026."
    />
    <p class="max-w-3xl mx-auto font-sans text-lg text-gray-700 leading-relaxed text-center mb-12">
      Découvrez notre programmation qui mêle grands classiques, œuvres moins connues et un projet de recherche consacré à la compositrice oubliée Alice Lesur, à qui nous rendons hommage cette année. Cliquez sur une affiche pour en savoir plus.
    </p>
    <ConcertCarousel concerts={concerts} />
  </section>
</BaseLayout>
