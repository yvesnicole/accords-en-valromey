---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/ui/Card.astro';
import { useTranslations } from '../i18n/utils';

const t = useTranslations('fr');
---

<BaseLayout title="Contact — Accords en Valromey" description="Contactez le festival Accords en Valromey">
  <section class="relative h-64 md:h-80 overflow-hidden">
    <div class="absolute inset-0 bg-[#1A1A1A]/40 z-10"></div>
    <img
      src="/images/scenery/paysage.jpg"
      alt="Valromey"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="relative z-20 flex items-center justify-center h-full">
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-contrast">Contact</h1>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 py-section">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <Card>
        <h3 class="font-serif text-xl font-semibold text-[#1A1A1A] mb-4">{t('contact.address')}</h3>
        <address class="font-sans text-gray-700 not-italic leading-relaxed">
          Festival Accords en Valromey<br />
          Mairie de Champagne-en-Valromey<br />
          01260 Champagne-en-Valromey<br />
          France
        </address>
      </Card>
      <Card>
        <h3 class="font-serif text-xl font-semibold text-[#1A1A1A] mb-4">{t('contact.email')}</h3>
        <p class="font-sans text-gray-700">
          <a href="mailto:contact@accordsenvalromey.fr" class="text-[#1A1A1A] underline hover:text-sage transition-colors">
            contact@accordsenvalromey.fr
          </a>
        </p>
      </Card>
      <Card>
        <div class="rounded-card overflow-hidden h-full min-h-64">
          <iframe
            src="https://maps.google.com/maps?q=Mairie+de+Champagne-en-Valromey+01260+France&t=&z=13&ie=UTF8&iwloc=&output=embed"
            width="100%"
            height="100%"
            style="border:0; min-height: 256px;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Carte de Champagne-en-Valromey"
          ></iframe>
        </div>
      </Card>
    </div>
  </section>
</BaseLayout>
