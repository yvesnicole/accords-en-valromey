---
import { getContactInfo } from '../../lib/data';
import { getLangFromUrl } from '../../i18n/utils';

const locale = getLangFromUrl(Astro.url) as 'fr' | 'en';
const contact = await getContactInfo(locale);
const currentYear = new Date().getFullYear();
---

<footer class="bg-[#1A1A1A] text-gray-300 mt-section">
  <div class="max-w-7xl mx-auto px-6 py-12 grid grid-cols-1 md:grid-cols-3 gap-8">
    <div>
      <p class="font-serif text-lg text-contrast mb-2">Accords en Valromey</p>
      <p class="text-sm leading-relaxed">
        {locale === 'fr' ? 'Festival de musique classique' : 'Classical music festival'}<br />
        Champagne-en-Valromey, Ain
      </p>
    </div>
    <div>
      <p class="font-sans font-semibold text-contrast mb-3">{locale === 'fr' ? 'Liens' : 'Links'}</p>
      <ul class="space-y-2 text-sm">
        <li><a href={locale === 'fr' ? '/le-festival/' : '/en/the-festival/'} class="hover:text-contrast transition-colors">{locale === 'fr' ? 'Le Festival' : 'The Festival'}</a></li>
        <li><a href={locale === 'fr' ? '/programmation/' : '/en/program/'} class="hover:text-contrast transition-colors">{locale === 'fr' ? 'Programmation' : 'Program'}</a></li>
        <li><a href={locale === 'fr' ? '/billetterie/' : '/en/tickets/'} class="hover:text-contrast transition-colors">{locale === 'fr' ? 'Billetterie' : 'Tickets'}</a></li>
        <li><a href={locale === 'fr' ? '/contact/' : '/en/contact/'} class="hover:text-contrast transition-colors">{locale === 'fr' ? 'Contact' : 'Contact'}</a></li>
      </ul>
    </div>
    <div>
      <p class="font-sans font-semibold text-contrast mb-3">{locale === 'fr' ? 'Suivez-nous' : 'Follow us'}</p>
      <ul class="space-y-2 text-sm">
        {contact?.facebookUrl && (
          <li><a href={contact.facebookUrl} target="_blank" rel="noopener noreferrer" class="hover:text-contrast transition-colors">Facebook</a></li>
        )}
        {contact?.instagramUrl && (
          <li><a href={contact.instagramUrl} target="_blank" rel="noopener noreferrer" class="hover:text-contrast transition-colors">Instagram</a></li>
        )}
      </ul>
    </div>
  </div>
  <div class="border-t border-gray-700 text-center py-6 text-xs text-gray-500">
    &copy; {currentYear} Accords en Valromey. {locale === 'fr' ? 'Tous droits réservés.' : 'All rights reserved.'}
  </div>
</footer>