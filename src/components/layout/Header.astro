---
const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/le-festival/', label: 'Le Festival' },
  { href: '/programmation/', label: 'Programmation' },
  { href: '/musiciens/', label: 'Musiciens' },
  { href: '/billetterie/', label: 'Billetterie' },
  { href: '/soutenir/', label: 'Nous Soutenir' },
  { href: '/contact/', label: 'Contact' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-ivory/90 backdrop-blur-sm border-b border-gray-300/50">
  <nav class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="font-serif text-xl font-bold text-[#1A1A1A]">
      Accords en Valromey
    </a>
    <div class="hidden lg:flex items-center gap-6">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="font-sans text-sm text-gray-700 hover:text-[#1A1A1A] transition-colors"
        >
          {link.label}
        </a>
      ))}
    </div>
    <!-- Mobile menu trigger placeholder -->
    <button class="lg:hidden p-2" aria-label="Menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>
</header>
