---
interface Props {
  label: string;
  variant?: 'sage' | 'gray';
}

const { label, variant = 'sage' } = Astro.props;

const variants: Record<string, string> = {
  sage: 'bg-sage/30 text-[#1A1A1A]',
  gray: 'bg-gray-100 text-gray-700',
};
---

<span class={`inline-block px-3 py-1 rounded-full text-xs font-sans font-semibold ${variants[variant]}`}>
  {label}
</span>
