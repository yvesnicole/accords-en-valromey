---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="max-w-3xl mx-auto text-center py-section">
  <h2 class="font-serif text-4xl font-bold text-[#1A1A1A] mb-4">
    {title}
  </h2>
  {subtitle && (
    <p class="font-sans text-lg text-gray-700 leading-relaxed">
      {subtitle}
    </p>
  )}
</div>
