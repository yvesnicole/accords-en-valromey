---
interface Props {
  href: string;
  label: string;
}

const { href, label } = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class="inline-flex items-center justify-center px-8 py-4 bg-sage text-[#1A1A1A] rounded-card font-semibold text-lg hover:bg-sage/80 transition-colors"
>
  {label}
</a>
